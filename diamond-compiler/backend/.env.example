# Diamond Backend — Environment Variables
# Copy this file to .env and adjust values as needed.

# Server port (default: 4000)
PORT=4000

# Environment: "development" or "production"
NODE_ENV=development

# Path to the Diamond compiler binary (default: ../../diamond.exe relative to src/)
# DIAMOND_COMPILER_BIN=C:\path\to\diamond.exe

# Allowed CORS origins (comma-separated). Use * for all origins.
# REQUIRED in production — server will reject cross-origin requests if unset.
# CORS_ORIGIN=http://localhost:3000,https://diamond-ide.vercel.app

# Maximum simultaneous compilation processes (default: 4)
# MAX_CONCURRENT=4

# Cluster workers for start:cluster (default: min(CPU count, 4))
# CLUSTER_WORKERS=4
